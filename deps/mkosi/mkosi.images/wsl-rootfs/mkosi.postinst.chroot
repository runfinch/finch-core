#!/bin/sh
set -x

# enable systemd
cat >> /etc/wsl.conf <<EOF
[boot]
systemd=true
EOF

# remove ec2-user from cloud-init config (clashes wwith lima user in WSL with UID=1000)
cat > /etc/cloud/cloud.cfg.d/99-no-default-user.cfg <<EOF
users: []
system_info:
  default_user:
    name: ""
EOF

# disable imds in cloud-init
cat > /etc/cloud/cloud.cfg.d/99-disable-imds.cfg <<EOF
datasource_list: [None]
datasource:
    None: {}
EOF

rm -f /etc/NetworkManager/system-connections/*.nmconnection
